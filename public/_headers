# Long-lived cache for static media (fixes "efficient cache lifetime").
# Filenames are stable; to bust an image, rename the file (or re-export under a
# new name) and update its reference. Astro's hashed /_astro/* assets already
# get immutable caching from Netlify automatically.
/assets/*
  Cache-Control: public, max-age=31536000
/uploads/*
  Cache-Control: public, max-age=31536000
