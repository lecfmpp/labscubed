---
// FAQ — native <details name="faq"> gives exclusive single-open with ZERO JS
// (per handoff §4), stays crawlable, and the same data feeds the FAQPage
// JSON-LD in the layout. First item open by default. Custom +/- icon.
import Section from './Section.astro';
import { FAQ_DATA } from '../lib/faq';
---
<Section bg="#fff">
  <div class="faq-inner">
    <div class="faq-head">
      <div class="faq-badge-wrap"><span class="lc-badge-subtle">Support</span></div>
      <h2 class="faq-title lc-gradtext">Frequently asked questions</h2>
    </div>
    <div class="faq-list">
      {FAQ_DATA.map(([q, a], i) => (
        <details class="faq-item" name="faq" open={i === 0}>
          <summary class="faq-summary">
            <span class="faq-q">{q}</span>
            <span class="faq-icon">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M1 7h12" stroke="var(--lc-ink)" stroke-width="1.6" stroke-linecap="round"></path>
                <path class="faq-vbar" d="M7 1v12" stroke="var(--lc-ink)" stroke-width="1.6" stroke-linecap="round"></path>
              </svg>
            </span>
          </summary>
          <p class="faq-a">{a}</p>
        </details>
      ))}
    </div>
  </div>
</Section>

<style>
  .faq-inner { padding: 128px 0; display: flex; flex-direction: column; align-items: center; gap: 90px; }
  .faq-head { text-align: center; }
  .faq-badge-wrap { display: flex; justify-content: center; margin-bottom: 16px; }
  .lc-badge-subtle { display: inline-flex; background: var(--lc-gray-100); color: var(--text-muted); border-radius: 4px; padding: 5px 12px; font-weight: 700; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; line-height: 1; }
  .faq-title { font-weight: 600; font-size: 100px; letter-spacing: -0.02em; line-height: 1.05; margin: 0; max-width: 840px; }
  .faq-list { width: 100%; display: flex; flex-direction: column; }

  .faq-item { border-bottom: 1px solid var(--lc-line); }
  .faq-summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 24px; width: 100%; padding: 24px 0; }
  .faq-summary::-webkit-details-marker { display: none; }
  .faq-q { font-weight: 500; font-size: 20px; letter-spacing: -0.01em; color: var(--lc-ink); }
  .faq-icon { width: 32px; height: 32px; flex: none; border-radius: 9999px; background: var(--lc-gray-100); display: inline-flex; align-items: center; justify-content: center; }
  .faq-vbar { opacity: 1; transition: opacity .2s; }
  .faq-item[open] .faq-vbar { opacity: 0; }
  .faq-a { max-width: 840px; font-weight: 300; font-size: 16px; line-height: 1.6; color: var(--text-muted); margin: 0; padding-bottom: 24px; }

  @media (max-width: 760px) {
    .faq-inner { padding: 80px 0; gap: 48px; }
    .faq-title { font-size: 40px; }
  }
</style>
