---
// CTABanner — white-paper email capture.
// Wired to the existing Supabase edge function `download-request`, which
// validates the (work) email, emails the "Beyond the Bottleneck" white-paper
// PDF via Resend, and logs the lead into webform_leads. Same contract + UX as
// the Webflow cubeten-form-wiring script. The .lc-cta-input class is the hook.
---
<section class="cta">
  <img class="cta-img-desktop" src="/assets/img/media/white-paper-mockup.webp" alt="LabsCubed automation white paper" width="1500" height="1800" loading="lazy" />
  <div class="cta-overlay"></div>
  <div class="cta-inner">
    <div class="cta-content">
      <div class="cta-tag">White Paper</div>
      <h2 class="cta-h2">Beyond the bottleneck: a data-backed case for testing automation.</h2>
      <p class="cta-p">Download your business case for automation — the definitive data on cost reduction and eliminating human error.</p>
      <form class="cta-form" onsubmit="event.preventDefault();return false;">
        <input class="lc-cta-input cta-input" placeholder="Enter your email address" aria-label="Email address" />
        <span class="cta-form-glow"></span>
        <button type="submit" class="cta-form-btn">
          <span class="cta-form-btn-label">Download Now</span>
          <span class="cta-form-btn-circle"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M7 17 17 7M17 7H9M17 7v8" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
        </button>
      </form>
      <img class="cta-img-mobile" src="/assets/img/media/white-paper-mockup.webp" alt="LabsCubed automation white paper" width="1500" height="1800" loading="lazy" />
    </div>
  </div>
</section>

<style>
  .cta { background: #000; color: #fff; position: relative; overflow: hidden; border-top: 1px solid rgba(255,255,255,0.06); border-bottom: 1px solid rgba(255,255,255,0.06); }
  .cta-img-desktop { position: absolute; right: 4%; top: 50%; transform: translateY(-50%); width: 42%; height: auto; max-width: 560px; pointer-events: none; z-index: 0; }
  .cta-overlay { position: absolute; inset: 0; background: linear-gradient(270deg, rgba(0,0,0,0) 60%, #000 100%); pointer-events: none; z-index: 1; }
  .cta-inner { position: relative; z-index: 2; max-width: 1392px; margin: 0 auto; padding: 150px 64px; box-sizing: border-box; }
  .cta-content { max-width: 591px; }
  .cta-tag { margin-bottom: 20px; display: inline-flex; align-items: center; padding: 4px 12px; border-radius: 4px; background: rgba(255,255,255,0.1); font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.85); }
  .cta-h2 { font-weight: 500; font-size: 64px; letter-spacing: -0.04em; line-height: 1.15; margin: 0; color: #fff; }
  .cta-p { margin-top: 22px; font-weight: 400; font-size: 24px; line-height: 1.4; color: rgba(255,255,255,0.5); }
  .cta-form { margin-top: 36px; position: relative; display: flex; align-items: center; width: 423px; max-width: 423px; height: 61px; background: rgba(255,255,255,0.1); border-radius: 1000px; padding: 8px; box-sizing: border-box; }
  .cta-input { flex: 1; min-width: 0; background: transparent; border: none; outline: none; color: #fff; font-weight: 500; font-size: 14px; padding-left: 25px; }
  .cta-form-glow { position: absolute; right: 8px; width: 184px; height: 45px; border-radius: 43px; background: #17DDC5; opacity: 0.5; filter: blur(40px); pointer-events: none; }
  .cta-form-btn { position: relative; display: inline-flex; align-items: center; height: 45px; background: #17DDC5; border-radius: 43px; border: none; cursor: pointer; padding: 0 4px 0 22px; flex: none; }
  .cta-form-btn-label { font-weight: 500; font-size: 14px; color: #000; opacity: 0.9; }
  .cta-form-btn-circle { width: 38px; height: 38px; border-radius: 50%; background: #000; display: inline-flex; align-items: center; justify-content: center; margin-left: 12px; }
  .cta-img-mobile { display: none; }

  @media (max-width: 760px) {
    .cta-img-desktop, .cta-overlay { display: none; }
    .cta-inner { padding: 80px 20px; }
    .cta-h2 { font-size: 34px; }
    .cta-p { font-size: 17px; }
    .cta-form { width: 100%; }
    .cta-input { padding-left: 18px; }
    .cta-form-btn { padding: 0 4px 0 16px; }
    .cta-img-mobile { display: block; width: 100%; height: auto; max-width: 420px; margin-top: 32px; border-radius: 12px; }
  }
</style>

<script>
  // Wire the white-paper form to the Supabase `download-request` edge function.
  // Emails the gated PDF via Resend + logs the lead. Mirrors the Webflow wiring.
  const ENDPOINT = "https://grozewxrymeiruhggcdy.supabase.co/functions/v1/download-request";
  const UTM_KEYS = ["utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term"];
  const COOKIE = "lc_first_touch";
  const MAX_AGE = 60 * 60 * 24 * 90; // 90 days
  const EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

  function getCookie(name: string): string {
    const m = document.cookie.match("(^|;)\\s*" + name + "\\s*=\\s*([^;]+)");
    return m ? decodeURIComponent(m.pop() as string) : "";
  }
  function setCookie(name: string, value: string): void {
    document.cookie = `${name}=${encodeURIComponent(value)};path=/;max-age=${MAX_AGE};SameSite=Lax`;
  }
  function currentUtms(): Record<string, string> | null {
    const p = new URLSearchParams(location.search);
    const o: Record<string, string> = {};
    let any = false;
    UTM_KEYS.forEach((k) => { const v = p.get(k); if (v) { o[k] = v; any = true; } });
    return any ? o : null;
  }
  // First-touch attribution: persist the first UTM set we ever see for this visitor.
  function firstTouch(): Record<string, string> {
    let s: Record<string, string> = {};
    try { s = JSON.parse(getCookie(COOKIE) || "{}") || {}; } catch { s = {}; }
    const has = s.utm_source || s.utm_medium || s.utm_campaign || s.utm_content || s.utm_term;
    if (!has) {
      const cur = currentUtms();
      if (cur) {
        cur.landing_page = location.pathname;
        cur.referrer = document.referrer || "";
        cur.ts = new Date().toISOString();
        setCookie(COOKIE, JSON.stringify(cur));
        s = cur;
      }
    }
    return s;
  }

  function wire(form: HTMLFormElement): void {
    const input = form.querySelector<HTMLInputElement>(".lc-cta-input");
    const label = form.querySelector<HTMLElement>(".cta-form-btn-label");
    if (!input || !label) return;
    const setLabel = (t: string) => { label.textContent = t; };

    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = (input.value || "").trim();
      if (!EMAIL_RE.test(email)) { setLabel("Enter a valid email"); return; }

      setLabel("Sending…");
      input.disabled = true;
      const ft = firstTouch();

      fetch(ENDPOINT, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          email,
          source: location.pathname,
          asset: "whitepaper",
          utm_source: ft.utm_source || "",
          utm_medium: ft.utm_medium || "",
          utm_campaign: ft.utm_campaign || "",
          utm_content: ft.utm_content || "",
          utm_term: ft.utm_term || "",
          referrer: ft.referrer || document.referrer || "",
          landing_page: ft.landing_page || location.pathname,
        }),
      })
        .then((r) => r.json().catch(() => ({})).then((d) => ({ status: r.status, data: d })))
        .then(({ status, data }) => {
          if (status === 200 && data && data.success) { setLabel("Check your inbox!"); input.value = ""; }
          else if (status === 422) { setLabel("Use your work email"); }
          else { setLabel("Try again"); }
          input.disabled = false;
        })
        .catch(() => { setLabel("Try again"); input.disabled = false; });
    });
  }

  firstTouch(); // capture attribution on landing
  document.querySelectorAll<HTMLFormElement>(".cta-form").forEach(wire);
</script>
