---
// Industries — three cards. <image-slot> replaced with a plain <img> + overlay
// (image-slot is an editor placeholder; real src is provided).
const cards = [
  { src: '/assets/img/industries/automotive.webp', title: 'Automotive & Transportation', body: 'Validate rubbers and plastics for extreme on-road stress and durability.' },
  { src: '/assets/img/industries/health.webp', title: 'Medical Devices & Healthcare', body: 'Ensure precision and integrity in critical fluid-delivery components.' },
  { src: '/assets/img/industries/additive.webp', title: 'Additive Manufacturing & Advanced Compounding', body: 'Characterize printed and compounded materials with repeatable accuracy.' },
];
---
<section class="ind">
  <div class="ind-inner">
    <div class="ind-head">
      <h2 class="ind-h2">Built for the most demanding industries.</h2>
      <p class="ind-sub">LabsCubed systems are deployed worldwide in facilities where failure is not an option.</p>
    </div>
    <div class="ind-grid">
      {cards.map((c) => (
        <div class="lc-icard ind-card">
          <img class="ind-card-img" src={c.src} alt={c.title} loading="lazy" />
          <div class="ind-card-overlay"></div>
          <span class="ind-card-arrow">
            <span style="color:#fff"><svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M7 17 17 7M17 7H9M17 7v8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg></span>
          </span>
          <div class="ind-card-body">
            <span class="ind-card-tick"></span>
            <div class="ind-card-title">{c.title}</div>
            <div class="ind-card-text">{c.body}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ind { background: var(--lc-gray-100); }
  .ind-inner { max-width: 1312px; margin: 0 auto; padding: 130px 64px; box-sizing: border-box; }
  .ind-head { text-align: center; max-width: 580px; margin: 0 auto; }
  .ind-h2 { font-weight: 700; font-size: 56px; letter-spacing: -0.03em; line-height: 1.07; margin: 0; color: var(--lc-ink); }
  .ind-sub { margin-top: 16px; font-weight: 300; font-size: 18px; line-height: 1.55; color: var(--text-muted); }
  .ind-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(210px, 1fr)); gap: 20px; margin-top: 72px; }
  .ind-card { position: relative; border-radius: 32px; overflow: hidden; min-height: 384px; background: var(--lc-ink); box-shadow: var(--shadow-edge); transition: transform .2s ease, box-shadow .2s ease; }
  .ind-card-img { position: absolute; inset: 0; width: 100%; height: 100%; display: block; object-fit: cover; }
  .ind-card-overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.85) 75%, rgba(0,0,0,0.95) 100%); pointer-events: none; }
  .ind-card-arrow { position: absolute; top: 18px; right: 18px; width: 18px; height: 44px; border-radius: 9999px; background: rgba(255,255,255,0.16); display: inline-flex; align-items: center; justify-content: center; pointer-events: none; }
  .ind-card-body { position: absolute; left: 26px; right: 26px; top: 200px; pointer-events: none; }
  .ind-card-tick { display: block; width: 28px; height: 3px; border-radius: 2px; background: var(--lc-teal); margin-bottom: 14px; }
  .ind-card-title { font-weight: 600; font-size: 20px; letter-spacing: -0.01em; line-height: 1.18; color: #fff; }
  .ind-card-text { margin-top: 8px; font-size: 14px; line-height: 1.5; color: rgba(255,255,255,0.72); }

  @media (max-width: 760px) {
    .ind-inner { padding: 80px 20px; }
    .ind-h2 { font-size: 32px; }
    .ind-sub { font-size: 16px; }
    .ind-grid { grid-template-columns: 1fr; gap: 16px; margin-top: 40px; }
  }
</style>
