---
// Trust — partner logo marquee. Pure CSS animation (lcMarquee), pauses on hover.
import Section from './Section.astro';

const partners = [
  { src: '/assets/img/partners/parker-hannifin.png', alt: 'Parker Hannifin', h: 42, w: 3840, nh: 2160 },
  { src: '/assets/img/partners/chevron-phillips.png', alt: 'Chevron Phillips Chemical', h: 50, w: 250, nh: 134 },
  { src: '/assets/img/partners/caterpillar.svg', alt: 'Caterpillar', h: 36, w: 392, nh: 64 },
  { src: '/assets/img/partners/wacker.svg', alt: 'Wacker', h: 40, w: 187, nh: 42 },
  { src: '/assets/img/partners/hexpol.webp', alt: 'HEXPOL', h: 28, w: 312, nh: 52 },
  { src: '/assets/img/partners/ace.webp', alt: 'ACE Laboratories', h: 44, w: 224, nh: 64 },
  { src: '/assets/img/partners/momentive.webp', alt: 'Momentive', h: 28, w: 312, nh: 52 },
  { src: '/assets/img/partners/soucy.webp', alt: 'Soucy', h: 30, w: 312, nh: 52 },
];
const doubled = [...partners, ...partners];
---
<Section bg="#fff" style="padding-top:0">
  <div class="trust-inner">
    <h2 class="trust-h2">Powering the automated workflows of the industry's most advanced polymer and elastomer labs.</h2>
    <div class="trust-mask">
      <div class="lc-logo-track trust-track">
        {doubled.map((p, i) => (
          <img src={p.src} alt={i < partners.length ? p.alt : ''} aria-hidden={i >= partners.length} style={`--h:${p.h}px`} width={p.w} height={p.nh} loading="lazy" />
        ))}
      </div>
    </div>
    <div class="trust-hr"></div>
  </div>
</Section>

<style>
  .trust-inner { padding: 150px 0 90px; }
  .trust-h2 { font-weight: 700; font-size: 56px; line-height: 1.18; letter-spacing: -0.02em; margin: 0; max-width: 1014px; }
  .trust-mask { margin-top: 80px; overflow: hidden; -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 7%, #000 93%, transparent 100%); mask-image: linear-gradient(90deg, transparent 0, #000 7%, #000 93%, transparent 100%); }
  .trust-track { display: flex; align-items: center; width: max-content; animation: lcMarquee 34s linear infinite; }
  .trust-track img { height: var(--h); width: auto; object-fit: contain; flex: none; margin-right: 72px; filter: grayscale(1); opacity: 0.5; }
  .trust-hr { height: 1px; background: var(--lc-line-strong); margin-top: 90px; }

  @media (max-width: 760px) {
    .trust-inner { padding: 80px 0 60px; }
    .trust-h2 { font-size: 30px; }
    .trust-mask { margin-top: 48px; }
    .trust-track img { height: calc(var(--h) * 0.84); margin-right: 48px; }
    .trust-hr { margin-top: 56px; }
  }
</style>
